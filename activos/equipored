from .equipo import Equipo

class Equipored(Equipo):
    def __init__(self, id=None, marca=None, modelo=None, estado="disponible", ubicacion=None, fecha_compra=None, tipo_red=None):
        super().__init__(id, marca, modelo, estado, ubicacion, fecha_compra)
        self.tipo_red = tipo_red
    
    def obtener_tipo(self):
        return f"Tipo de equipo: {self.tipo_red}"

